# Security: Environment secrets - NEVER COMMIT REAL KEYS
# Core environment files
.env
.env.*
*.local
config.local.js
env.js
shared/core/env.js

# Backend/Script Environment Secrets (NEVER commit these)
# Only backend .env files with real secrets are ignored
scripts/**/.env
scripts/**/.env.*
!scripts/**/.env.example
**/*.local
config.local.js

# NOTE: Frontend env.js contains PUBLIC Supabase Anon-Key in some deployments,
# but it is kept out of global version control to prevent credential leakage.
# Users should use env.example.js as a template.

# Data Cache & Temp Files (SECURITY: Prevent data leaks)
AI/models/data/*.json
shared/data/market_sentiment.json
shared/data/*.local.json
*.cache.json
.temp/
.supabase/
coverage/

# Backup files (SECURITY: Prevent code/secret leaks via backups)
**/*.bak
