# MBRN Data Arbitrage - Environment Configuration
# Copy this file to .env and fill in your actual values

# Supabase Edge Function Configuration
SUPABASE_EDGE_FUNCTION_URL=https://your-project.supabase.co/functions/v1/market_sentiment
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Data Arbitrage API Key (for Edge Function Bearer authentication)
# Must match DATA_ARB_API_KEY in Supabase Edge Function environment
DATA_ARB_API_KEY=your-data-arbitrage-api-key-here

# Optional: Local development settings
DEBUG=false
